FROM python:3.12-slim

WORKDIR /app

# Install dependencies
COPY pyproject.toml .
RUN pip install --no-cache-dir .

# Copy application code
COPY markwritter/ ./markwritter/
COPY skills/ ./skills/
COPY config.yaml .

EXPOSE 8000

CMD ["uvicorn", "markwritter.api.app:get_app", "--host", "0.0.0.0", "--port", "8000", "--factory"]
